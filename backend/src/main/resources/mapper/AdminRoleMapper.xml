<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.admanager.admin.mapper.AdminRoleMapper">

    <resultMap id="adminRoleMap" type="com.admanager.admin.model.AdminRole">
        <id property="id" column="id"/>
        <result property="roleCode" column="role_code"/>
        <result property="displayName" column="display_name"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectById" resultMap="adminRoleMap">
        SELECT * FROM admin_roles WHERE id = #{id}
    </select>

    <select id="selectByRoleCode" resultMap="adminRoleMap">
        SELECT * FROM admin_roles WHERE role_code = #{roleCode}
    </select>

    <select id="selectAll" resultMap="adminRoleMap">
        SELECT * FROM admin_roles ORDER BY role_code ASC
    </select>

    <select id="selectByUserId" resultMap="adminRoleMap">
        SELECT r.*
        FROM admin_roles r
        INNER JOIN admin_user_roles ur ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
        ORDER BY r.role_code ASC
    </select>
</mapper>
